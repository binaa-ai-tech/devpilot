# =============================================================================
# Environment Variables — copy this file to .env and fill in values
# NEVER commit .env to git (it is gitignored by the installer)
# =============================================================================

# ── Jira API ─────────────────────────────────────────────────────────────────
# Used by: scripts/create-jira-ticket.sh, scripts/update-jira-status.sh
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=KEY

# ── Deploy Hooks ──────────────────────────────────────────────────────────────
# Used by: scripts/deploy-*.sh (manual re-trigger)
# These are also needed as GitHub Secrets for the CI pipeline
DEPLOY_HOOK_DEV_API=https://api.render.com/deploy/srv-XXXXXXXX?key=XXXXXXXX
DEPLOY_HOOK_DEV_UI=https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/XXXXXXXX
DEPLOY_HOOK_SIT=https://api.render.com/deploy/srv-XXXXXXXX?key=XXXXXXXX
DEPLOY_HOOK_UAT=https://your-azure-hook.azurewebsites.net/api/deploy?code=XXXXXXXX
DEPLOY_HOOK_PRD=https://your-azure-hook.azurewebsites.net/api/deploy?code=XXXXXXXX

# ── Environment URLs ──────────────────────────────────────────────────────────
# Used by: scripts/deploy-*.sh for output messages
# These are also needed as GitHub Variables (Settings → Secrets → Variables)
DEV_URL=https://your-app-dev.onrender.com
SIT_URL=https://your-app-sit.onrender.com
UAT_URL=https://your-app-uat.azurewebsites.net
PRD_URL=https://your-app.com
